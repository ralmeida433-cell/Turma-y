{
  "entities": {
    "Attendance": {
      "title": "Attendance",
      "description": "Presence status for a military member",
      "type": "object",
      "properties": {
        "present": {
          "type": "boolean",
          "description": "Whether the member is present"
        },
        "funcao": {
          "type": "string",
          "description": "Function of the member"
        },
        "telefone": {
          "type": "string",
          "description": "Phone number of the member"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last time the status was updated"
        }
      },
      "required": ["present", "updatedAt"]
    }
  },
  "firestore": {
    "/turmas/{turmaId}/attendance/{memberId}": {
      "schema": "Attendance",
      "description": "Collection of attendance records for each turma, indexed by member ID"
    }
  }
}
