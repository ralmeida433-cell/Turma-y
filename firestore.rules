rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isValidAttendance(data) {
      return data.keys().hasAll(['present', 'updatedAt']) &&
             data.present is bool &&
             data.updatedAt is timestamp &&
             (!('funcao' in data) || data.funcao is string) &&
             (!('telefone' in data) || data.telefone is string);
    }

    match /turmas/{turmaId}/attendance/{memberId} {
      // Allow read and write for authenticated users
      allow read: if true; // Publicly readable for now
      allow write: if isAuthenticated() && isValidAttendance(request.resource.data);
    }
  }
}
